# React + vtk.js SPA: build with Vite, serve static files via nginx (which also
# reverse-proxies /api to the backend service).
FROM node:20-slim AS build
WORKDIR /app
COPY app_react/package.json app_react/package-lock.json ./
RUN npm ci
COPY app_react/ ./
RUN npm run build

FROM nginx:alpine
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
